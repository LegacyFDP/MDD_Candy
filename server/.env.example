# Copy to .env and fill in. The server loads this automatically (dotenv).

# PostgreSQL connection string
DATABASE_URL=postgres://fete_user:CHANGE_ME@localhost:5432/fete_store

# Set to true if your Postgres requires TLS (most managed/cloud DBs do).
PGSSL=false

# Port and bind address for the Node server.
# Behind nginx, bind to localhost only.
PORT=8080
HOST=127.0.0.1
